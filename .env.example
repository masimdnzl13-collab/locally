# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Yalnız sunucu tarafında (cron işleri) kullanılır, asla client'a sızdırılmaz
SUPABASE_SERVICE_ROLE_KEY=

# Şifre sıfırlama e-postasındaki bağlantının döneceği adres (prod'da gerçek domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron uç noktalarını dıştan çağrılamaz yapan gizli anahtar
CRON_SECRET=

# SMS (Netgsm) — boşsa duyuru aracı test modunda simüle eder
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=

# E-posta (Resend) — boşsa duyuru aracı test modunda simüle eder
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# iyzico (marketplace/pazaryeri) — boşsa ödeme akışı test modunda simüle eder
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
